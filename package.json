{
	"name": "abilities-api",
	"type": "module",
	"license": "GPL-2.0-or-later",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/WordPress/abilities.git"
	},
	"engines": {
		"node": ">=20.10.0",
		"npm": ">=10.2.3"
	},
	"workspaces": [
		"packages/*"
	],
	"devDependencies": {
		"@wordpress/env": "^10.28.0",
		"@wordpress/scripts": "^30.21.0",
		"@wordpress/prettier-config": "^4.28.0",
		"@testing-library/jest-dom": "^6.1.5",
		"@testing-library/react": "^14.1.2",
		"@types/jest": "^30.0.0",
		"@wordpress/eslint-plugin": "^22.16.0",
		"@wordpress/jest-console": "^8.30.0",
		"eslint": "^8.57.0",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jest": "^27.9.0",
		"typescript": "^5.9.2"
	},
	"files": [
		"docs",
		"includes",
		"LICENSE.md",
		"README.md",
		"abilities-api.php"
	],
	"scripts": {
		"plugin-zip": "wp-scripts plugin-zip",
		"build": "npm run build --workspace=@wordpress/abilities",
		"dev": "npm run dev --workspace=@wordpress/abilities",
		"format": "wp-scripts format",
		"format:js": "npm run format --workspace=@wordpress/abilities",
		"lint:js": "npm run lint:js --workspace=@wordpress/abilities",
		"lint:js:fix": "npm run lint:js:fix --workspace=@wordpress/abilities",
		"lint:php": "wp-env run tests-cli --env-cwd=wp-content/plugins/$(basename \"$(pwd)\")/ composer run-script lint",
		"lint:php:fix": "wp-env run tests-cli --env-cwd=wp-content/plugins/$(basename \"$(pwd)\")/ composer run-script format",
		"lint:php:stan": "wp-env run tests-cli --env-cwd=wp-content/plugins/$(basename \"$(pwd)\")/ composer run-script phpstan",
		"lint:all": "npm run lint:php && npm run lint:js && npm run typecheck",
		"typecheck": "npm run typecheck --workspace=@wordpress/abilities",
		"test:php": "wp-env run tests-cli --env-cwd=wp-content/plugins/$(basename \"$(pwd)\")/ vendor/bin/phpunit -c phpunit.xml.dist",
		"test:client": "npm run test:unit --workspace=@wordpress/abilities",
		"test:client:watch": "npm run test:unit:watch --workspace=@wordpress/abilities",
		"test:client:coverage": "npm run test:unit:coverage --workspace=@wordpress/abilities",
		"test:all": "npm run test:php && npm run test:client",
		"wp-env": "wp-env"
	}
}
